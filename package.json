{
  "name": "cowire",
  "version": "0.1.0",
  "description": "Cowire \u2014 MCP-native broker (Switch) between Co, CC, and user channels.",
  "type": "module",
  "bin": {
    "cowire": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:tools": "tsx scripts/generate-tool-catalogue.ts",
    "check": "tsc --noEmit && vitest run && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "author": "Kenneth Stenlund <stenlund@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kstkoda/cowire.git"
  },
  "bugs": {
    "url": "https://github.com/Kstkoda/cowire/issues"
  },
  "homepage": "https://github.com/Kstkoda/cowire#readme",
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "agent",
    "orchestrator",
    "audit",
    "trust",
    "local-first",
    "sandbox"
  ]
}
