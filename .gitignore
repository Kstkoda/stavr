node_modules/
dist/
*.db
*.db-journal
*.db-wal
*.db-shm
.env
.env.*
!.env.example
*.log
.vscode/
.idea/
.DS_Store
coverage/
.stavr/

# spec 47 workspace state (per-worker worktrees, never commit)
.stavr-worktrees/

# Claude Code per-project state
.claude/

# Claude auto-memory bootstrap seed (private context, not for public repo)
.claude-memory-seed/

# Runtime memory dir (daemon writes here; never commit)
memory/

# Vitest config compilation temp files
vitest.config.ts.timestamp-*.mjs

# Transient operator/steward task files (never commit)
prompts/

# OOM diagnostics — heap snapshots and node --report dumps. Keep .gitkeep,
# never commit the .heapsnapshot / .report.*.json payloads themselves.
tmp/heap-snapshots/*
!tmp/heap-snapshots/.gitkeep
tmp/diag-reports/*
!tmp/diag-reports/.gitkeep

# v0.7 Phase 10a — peer-smoke regenerates these per run
tmp/perf/peer-smoke-artifacts/

# Repo-root heap snapshots (Node --heapsnapshot-near-heap-limit drops them here)
*.heapsnapshot

# Session-local design notes
.work/

# WinSW per-machine install artifacts — operator places the exe; the install
# script renders the xml. Never commit them (see bin/winsw/README.md).
bin/winsw/StavrDaemon.exe
bin/winsw/StavrDaemon.xml
