# spec 47 workspace state (per-worker worktrees, never commit)
.stavr-worktrees/

# Claude Code per-project state
.claude/

# Vitest config compilation temp files
vitest.config.ts.timestamp-*.mjs

# Transient operator/steward task files (never commit)
prompts/

# OOM diagnostics — heap snapshots and node --report dumps. Keep .gitkeep,
# never commit the .heapsnapshot / .report.*.json payloads themselves.
tmp/heap-snapshots/*
!tmp/heap-snapshots/.gitkeep
tmp/diag-reports/*
!tmp/diag-reports/.gitkeep
